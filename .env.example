# Supabase — variáveis de ambiente obrigatórias para produção
# Copie este arquivo como .env.local e preencha com suas credenciais do Supabase

# URL do projeto (pública)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Chave anônima (pública — usada no cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# NUNCA coloque a service_role key aqui ou no frontend.
# Use-a apenas em funções serverless seguras (routes, edge functions).
